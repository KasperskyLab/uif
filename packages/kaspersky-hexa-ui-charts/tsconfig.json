{
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    }
  },
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "noImplicitAny": true,
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "outDir": "dist",
    "allowJs": true,
    "jsx": "react",
    "paths": {
      "@sb/*": [".storybook/*"],
      "@src/*": ["src/*"]
    }
  },
  "include": ["./src/**/*"],
  "exclude": ["dist", "node_modules", "tests", "playwright.visual.config.ts"]
}
