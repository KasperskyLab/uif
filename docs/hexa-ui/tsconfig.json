{
  "compilerOptions": {
    "sourceMap": true,
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "node",
    "isolatedModules": true,
    "jsx": "react",
    "noImplicitAny": true,
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "outDir": "esm",
    "paths": {
      "@kaspersky/hexa-ui": ["../kl-hexa-ui/dist"],
      "@kaspersky/hexa-ui/*": ["../kl-hexa-ui/dist/*"]
    }
  },
  "tsc-alias": {
    "verbose": false,
    "resolveFullPaths": true
  },
  "include": [
    "./src/**/*"
  ],
  "exclude": [
    "node_modules",
    "lib",
    "esm"
  ],
  "files": ["fonts.d.ts"]
}
